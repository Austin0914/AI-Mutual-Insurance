{
  "name": "@ai-insurance/abi",
  "version": "0.0.0",
  "private": true,
  "description": "合約 ABI、位址與型別的單一來源，供前端（wagmi/viem）與後端共用。",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "gen": "wagmi generate",
    "gen:addresses": "tsx scripts/gen-addresses.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@wagmi/cli": "^2.5.0",
    "abitype": "^1.0.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

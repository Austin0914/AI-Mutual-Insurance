# 後端事件索引器環境變數範本。複製成 .env 後填入實際值；切勿將 .env 入版控。

# 鏈上 JSON-RPC 端點（本地 anvil 預設 8545）
RPC_URL=http://127.0.0.1:8545

# 目標鏈 ID（本地 anvil = 31337）
CHAIN_ID=31337

# PostgreSQL 連線字串
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ai_insurance

# 索引器起始區塊（首次啟動時的最小掃描區塊；之後以 checkpoint 為準）
START_BLOCK=0

# 安全確認數（toBlock = latest - CONFIRMATIONS，用以規避淺層 reorg）
CONFIRMATIONS=1

# 輪詢間隔（毫秒）
POLL_INTERVAL_MS=4000

# 單批最大掃描區塊數（避免一次抓過多 logs）
MAX_BLOCK_RANGE=2000

# 日誌等級：trace|debug|info|warn|error
LOG_LEVEL=info

# 查詢 API 監聽埠（前端透過此埠讀取索引器投影）
HTTP_PORT=4000

# 查詢 API 監聽主機
HTTP_HOST=127.0.0.1

# 允許跨來源讀取的前端來源（逗號分隔；'*' 代表全部放行）
CORS_ORIGIN=http://localhost:3000
